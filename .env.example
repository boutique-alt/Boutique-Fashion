# Razorpay (public key only — secret stays on backend)
VITE_RAZORPAY_KEY_ID=

# Supabase — get from Project Settings → API (required on Vercel for admin/cloud products)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# UPI (change later with your real business UPI ID)
VITE_UPI_ID=boutique@upi
VITE_UPI_PAYEE_NAME=Boutique Fashion

# Resend (server-side only — set in Supabase Edge Function secrets, NOT here)
# supabase secrets set RESEND_API_KEY=re_xxx
# supabase secrets set EMAIL_FROM="Boutique Fashion <orders@yourdomain.com>"
# supabase secrets set REPLY_TO_EMAIL=theboutiquesarees@gmail.com
# supabase secrets set ADMIN_NOTIFY_EMAIL=theboutiquesarees@gmail.com
# supabase secrets set SITE_URL=https://your-site.com
# Optional webhook: EMAIL_WEBHOOK_SECRET=your-random-secret

# Google Analytics 4
VITE_GA_MEASUREMENT_ID=
