# Razorpay (public key only — secret stays on backend)
VITE_RAZORPAY_KEY_ID=

# Supabase — get from Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# UPI (change later with your real business UPI ID)
VITE_UPI_ID=boutique@upi
VITE_UPI_PAYEE_NAME=Boutique Fashion

# Admin login — change these, then restart dev server (npm run dev)
VITE_ADMIN_EMAIL=admin@boutiquefashion.com
VITE_ADMIN_PASSWORD=admin123
